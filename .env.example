# ----- group service environment ---------------------------------------
# Required
SERVICE_NAME=group
DATABASE_URL=postgresql+psycopg://postgres:dev_pw@group_db:5432/group_db
PUBSUB_PROJECT_ID=local-eligibility
PUBSUB_EMULATOR_HOST=pubsub:8085

# Optional / observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
TENANT_DEFAULT=11111111-1111-1111-1111-111111111111

# Standalone (no docker-compose) overrides
# DATABASE_URL=postgresql+psycopg://postgres:dev_pw@localhost:5443/postgres
